# =============================================================================
# GAMEPILE — Environment Variables
#
# Copy this file to `.env` and fill in the values marked with placeholders.
# Variables without explicit defaults are required unless noted otherwise.
# =============================================================================

# ── Runtime ─────────────────────────────────────────────────────────────────

# Node environment. Controls Prisma singleton behaviour and default log labels.
# Accepted: development | production | test
# Required. Default: development
NODE_ENV=development

# Public DNS host used by docker-compose for WEB_APP_URL.
# Required for production docker deployments.
DOMAIN="gamepile.example.com"

# ── Database ────────────────────────────────────────────────────────────────

# PostgreSQL connection string used by Prisma in both the web and worker packages.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
# Automatically set by docker-compose in production. For local development, copy this format and fill in your credentials.
#DATABASE_URL="postgresql://gamepile:your-db-password@localhost:5432/gamepile?schema=public"

# ── Redis ───────────────────────────────────────────────────────────────────

# Redis host used for middleware rate limits, SSE coordination, BullMQ queues,
# and worker jobs. Used by both web and worker packages.
# Required.
REDIS_HOST="localhost"

# Redis TCP port.
# Required. Default: 6379
REDIS_PORT=6379

# Redis password. Leave empty for local unsecured Redis.
# Required for production.
REDIS_PASSWORD="your-redis-password"

# Redis ACL username when the provider requires one.
# Optional. Omit if not needed.
# REDIS_USERNAME="default"

# ── Steam API ───────────────────────────────────────────────────────────────

# Steam Web API key used for profile metadata, owned-games lookups, and catalog sync.
# Obtain one at https://steamcommunity.com/dev/apikey
# Required. Used by both web and worker packages.
STEAM_API_KEY="your-steam-api-key"

# ── Observability (OpenTelemetry / SigNoz) ──────────────────────────────────

# Base OTLP endpoint for traces and logs export.
# Required when observability is enabled.
# Example (SigNoz Cloud): https://ingest.us2.signoz.cloud:443
OTEL_EXPORTER_OTLP_ENDPOINT=https://ingest.us2.signoz.cloud:443

# Explicit traces endpoint. Falls back to OTEL_EXPORTER_OTLP_ENDPOINT if omitted.
# Optional.
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=https://ingest.us2.signoz.cloud:443/v1/traces

# Protocol for the traces exporter.
# Accepted: http/protobuf | grpc
# Optional. Default: http/protobuf
OTEL_EXPORTER_OTLP_TRACES_PROTOCOL=http/protobuf

# Comma-separated key=value pairs sent as HTTP headers on OTLP export requests.
# Example (SigNoz): signoz-ingestion-key=<your-key>
# Required when using SigNoz Cloud.
OTEL_EXPORTER_OTLP_HEADERS=signoz-ingestion-key=your-signoz-ingestion-key

# OTLP SDK log verbosity.
# Accepted: debug | info | warn | error
# Optional. Default: info
OTEL_LOG_LEVEL=info

# Next.js OpenTelemetry verbose output.
# Set to 1 for verbose OTel debug output in Next.js.
# Optional. Default: 0
NEXT_OTEL_VERBOSE=0

# Enable Prisma query-event logging for slow query warnings (>500ms).
# Set to false to disable Prisma query-event logging in both web and worker.
# Optional. Default: true
PRISMA_LOG_QUERIES=true

# =============================================================================
# WEB PACKAGE — Configuration specific to the Next.js web service
# =============================================================================

# ── Web App URL ─────────────────────────────────────────────────────────────

# Public application URL used for OpenID callbacks, sitemap URL generation,
# and the Next.js server-action origin allow-list.
# Required.
WEB_APP_URL="http://localhost:3000"

# Comma-separated hostname allow-list for Next.js Server Actions forwarding.
# Each entry can be a hostname (example.com) or full URL (https://example.com).
# Optional in dev; recommended in production.
WEB_ALLOWED_ORIGINS="localhost:3000"

# ── Session Management ──────────────────────────────────────────────────────

# Name of the primary auth session cookie.
# Optional. Default: __session
WEB_SESSION_COOKIE_NAME="__session"

# Session lifetime in days.
# Optional. Default: 7
WEB_SESSION_DURATION_DAYS="7"

# ── Vault Access Token Security ─────────────────────────────────────────────

# HMAC secret for per-vault access cookies. In production, set this to a long
# random value to avoid fallback-derived signing keys.
# Required for production. Web package only.
WEB_VAULT_TOKEN_SECRET="your-vault-token-secret"

# =============================================================================
# WORKER PACKAGE — Configuration specific to the background job worker
# =============================================================================

# ── Worker Throughput and Recovery ──────────────────────────────────────────

# Max concurrent parent/orchestrator jobs on the gamepile.jobs queue.
# Optional. Default: 3. Worker package only.
WORKER_JOBS_CONCURRENCY=3

# Max concurrent per-game detail jobs on the gamepile.game-details queue.
# Optional. Default: 10. Worker package only.
WORKER_DETAILS_CONCURRENCY=10

# Startup grace delay before beginning queue consumption (milliseconds).
# Optional. Default: 300000 (5 minutes). Worker package only.
WORKER_STARTUP_DELAY_MS=300000

# Age threshold for ACTIVE jobs to be considered stale (milliseconds).
# Jobs stuck in ACTIVE status longer than this are reset back to QUEUED.
# Optional. Default: 1800000 (30 minutes). Worker package only.
WORKER_STALE_ACTIVE_RECOVERY_DELAY_MS=1800000

# Redis lock TTL so only one worker performs stale ACTIVE recovery (milliseconds).
# Optional. Default: 60000 (1 minute). Worker package only.
WORKER_ACTIVE_RECOVERY_LOCK_TTL_MS=60000

# ── Steam Global Rate Limiter ──────────────────────────────────────────────

# Max Steam API calls allowed during each limiter window.
# Optional. Default: 200. Worker package only.
WORKER_STEAM_RATE_LIMIT_MAX=200

# Limiter window size in milliseconds.
# Optional. Default: 300000 (5 minutes). Worker package only.
WORKER_STEAM_RATE_LIMIT_WINDOW_MS=300000

# Minimum delay between consecutive Steam API calls in milliseconds.
# Optional. Default: 1500. Worker package only.
WORKER_STEAM_RATE_LIMIT_MIN_INTERVAL_MS=1500

# Budget coordination mode.
# Accepted: local (per worker) | distributed (shared via Redis)
# Optional. Default: local. Worker package only.
WORKER_STEAM_RATE_LIMIT_SCOPE=local

# ── Scheduled Jobs ──────────────────────────────────────────────────────────

# Cron expression for the full Steam catalog sync job.
# Optional. Default: "0 3 * * 0" (Sundays at 03:00). Worker package only.
WORKER_SYNC_STEAM_GAMES_CRON="0 3 * * 0"

# Cron expression for periodic stale game-details refresh.
# Optional. Default: "0 2 * * *" (daily at 02:00). Worker package only.
WORKER_REFRESH_GAME_DETAILS_CRON="0 2 * * *"

# Days after which fetched game details are considered stale.
# Optional. Default: 30. Worker package only.
WORKER_GAME_DETAILS_REFRESH_DAYS=30

# Interval for periodic refetching of user-owned games from Steam (milliseconds).
# Optional. Default: 604800000 (7 days). Worker package only.
WORKER_IMPORT_USER_LIBRARY_INTERVAL_MS=604800000

